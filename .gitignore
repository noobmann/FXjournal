.idea/

# System files
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Build directories
dist/
build/
target/
.gradle/

# Python specific
.mypy_cache/
.pytest_cache/

# Compressed files
*.zip
*.gz
*.tar
